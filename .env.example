# Copy to .env for local development: `cp .env.example .env`, then fill in.
# .env is git-ignored and must never be committed. This template is tracked and
# must never contain a real credential.
#
# In production these are set as real environment variables (GitHub Actions
# secrets / the VPS environment), not through a .env file — see ADR-015.

# Application database. Local dev uses a dedicated least-privilege role that owns
# the `vividi` database (mirrors production, where the app is not a superuser):
#   postgresql+psycopg://vividi:PASSWORD@localhost/vividi
# A passwordless local superuser also works: postgresql+psycopg://localhost/vividi
DATABASE_URL=postgresql+psycopg://vividi:PASSWORD@localhost/vividi

# Database used by the test suite. Overrides the default vividi_test.
# TEST_DATABASE_URL=postgresql+psycopg://localhost/vividi_test

# --- Twilio (telephony carrier, ADR-004) ---
# Account SID and Auth Token from the Console dashboard (console.twilio.com).
# The Auth Token is also what validates inbound webhook signatures, so it is
# required even where an API key would otherwise do.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The caller ID we place calls from, in E.164. This is the existing Twilio dev
# number — the demo has no Spanish number and no regulatory bundle (ADR-018).
TWILIO_PHONE_NUMBER=

# Public HTTPS base URL Twilio reaches us at (Traefik terminates TLS). Used to
# build the answer webhook and the wss:// stream URL, and to reconstruct the
# exact URL Twilio signed for webhook validation. This one value must match the
# number's webhook configuration in the Twilio Console (ADR-015).
#   e.g. https://phone-bot.bagaiev.com
PUBLIC_BASE_URL=

# --- OpenAI (Realtime API drives the conversation, ADR-002/ADR-011) ---
# Secret key from platform.openai.com/api-keys.
OPENAI_API_KEY=
# Realtime model that answers the call.
OPENAI_REALTIME_MODEL=gpt-realtime
